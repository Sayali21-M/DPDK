	//	    memset(&ip_spec, 0, sizeof(struct rte_flow_item_arp));
	//	    memset(&ip_mask, 0, sizeof(struct rte_flow_item_arp));

//
		    inet_aton("10.60.180.165", &ipv4_addr); // Convert string to binary format

		    ip_spec.hdr.src_addr = rte_cpu_to_be_32(ipv4_addr.s_addr);
		    ip_mask.hdr.src_addr = rte_cpu_to_be_32(0xFFFFFFFF);

	//	    pattern[2].type = RTE_FLOW_ITEM_TYPE_ARP;
	//	    pattern[2].spec = &arp_spec;
	//	    pattern[2].mask = &arp_mask;

		    /* End of pattern */
		    pattern[2].type = RTE_FLOW_ITEM_TYPE_END;

		    /* Validate and create flow */
		    res = rte_flow_validate(port_id, &attr, pattern, action, error);
