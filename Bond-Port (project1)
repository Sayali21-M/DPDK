void display_port_status(void) {
    struct rte_eth_link link;
    uint16_t port_id;

    printf("Checking link status for all ports...\n");

    // Iterate through all possible ports
    for (port_id = 0; port_id < 4; port_id++) {
        // Check if the port is valid
        if (rte_eth_dev_is_valid_port(port_id)) {
            // Get the link status
            rte_eth_link_get(port_id, &link);
            // Display information
            printf("Port %u: ", port_id);
            printf("Link status: %s, ", link.link_status == RTE_ETH_LINK_UP ? "up" : "down");
            printf("Link speed: %u Mbps, ", link.link_speed);
            printf("Link duplex: %s\n", link.link_duplex == RTE_ETH_LINK_FULL_DUPLEX ? "full-duplex" : "half-duplex");
        }
    }
}


